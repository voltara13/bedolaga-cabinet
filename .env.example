# ===== BUILD-TIME VARIABLES =====
# These variables are baked into the frontend JavaScript at build time
# If you change them, you need to rebuild: docker compose up -d --build

# API URL - How the browser will access the backend
# Same server (with proxy):  /api
# Remote server (direct):    https://api.yourbot.com/cabinet
VITE_API_URL=/api

# Telegram bot username for Login Widget (without @)
VITE_TELEGRAM_BOT_USERNAME=your_bot_username

# ===== BRANDING (optional) =====
# App name displayed in header and browser tab
VITE_APP_NAME=VPN Cabinet

# Short logo text (1-2 characters, displayed in logo icon)
VITE_APP_LOGO=V

# Legal info displayed in the footer (optional)
# Example: СЗ Иванов Иван Иванович ИНН 123456789012
VITE_LEGAL_INFO=

# Cabinet subdomain for landing/cabinet split setup (optional)
# When set, the SPA enforces the split:
#   - apex host serves only /home and /info
#   - everything else (including /login and auth flows) lives on the cabinet host
# Leave empty if you serve everything on a single host.
# Example: cabinet.example.com
VITE_CABINET_HOST=

# Explicit apex/public host (optional, only if it can't be derived from
# VITE_CABINET_HOST by stripping the first DNS label).
# Example: example.com
VITE_PUBLIC_HOST=

# ===== SEO / Social preview (Open Graph, Twitter Card) =====
# Title shown in browser tab and in link previews (VK, Telegram, etc.)
VITE_SEO_TITLE=VPN Cabinet

# Description used for <meta name="description"> and og:description
VITE_SEO_DESCRIPTION=Fast and secure VPN service.

# Absolute URL to preview image (recommended 1200x630px).
# If you placed the image in public/, just write: https://<VITE_PUBLIC_HOST>/<file>
# Example: https://example.com/og-preview.png
VITE_SEO_IMAGE=

# ===== RUNTIME VARIABLES =====

# Port to expose the frontend on host machine
# Default: 3020 (http://localhost:3020)
CABINET_PORT=3020
